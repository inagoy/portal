---
import { Image } from "astro:assets";
import type { Project } from "../types/config";
import { Markdown } from "@astropub/md";

type Props = Project;

const { title, description, image, year, url } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="project-row group/card"
>
  <div class="aspect-video overflow-hidden bg-[var(--soft)] sm:aspect-square">
    <Image
      width={1920}
      height={1080}
      src={image}
      alt={title}
      class="h-full w-full object-cover opacity-80 transition duration-300 group-hover/card:scale-[1.03] group-hover/card:opacity-100"
    />
  </div>
  <div class="min-w-0">
    <div class="flex items-start justify-between gap-4">
      <h2 class="font-medium leading-tight transition-all group-hover/card:line-through">{title}</h2>
      <span class="muted shrink-0 text-sm">{year}</span>
    </div>
    <div class="muted mt-2">
      <Markdown of={description} />
    </div>
  </div>
</a>
