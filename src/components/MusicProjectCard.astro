---
import { Image } from "astro:assets";
import type { Project } from "../types/config";
import { getStrings, normalizeLang, type Lang } from "../i18n";

type Props = Project & { lang?: Lang };

const { title, description, image, year, url, socio, lang, type } = Astro.props as Props;
const t = getStrings(normalizeLang(lang));
const descriptionText = description
  .split(/\s*,\s*|\s+(?:y|and)\s+/i)
  .map((tag) => tag.trim())
  .filter(Boolean)
  .join(', ')
  .toLowerCase();
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="project-row group/card"
>
  <div class="aspect-square overflow-hidden bg-[var(--soft)]">
    <Image
      width={1920}
      height={1080}
      src={image}
      alt={title}
      class="h-full w-full object-cover opacity-80 transition duration-300 group-hover/card:scale-[1.03] group-hover/card:opacity-100"
    />
  </div>
  <div class="min-w-0">
    <div class="flex items-start justify-between gap-4">
      <h2 class="font-medium leading-tight transition-all group-hover/card:line-through">{title}</h2>
      {year && <p class="muted shrink-0 text-sm">{year}</p>}
    </div>
    <p class="muted mt-2">{descriptionText}</p>
    {socio && (
      <p class="muted mt-3 text-sm">
        {t.labels.with}: {socio}
      </p>
    )}
    {type && <p class="muted mt-3 text-xs">{t.labels.types?.[type] ?? type}</p>}
  </div>
</a>
