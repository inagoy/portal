---
import type { Lang } from "../i18n";
interface Props { lang: Lang; esHref: string; enHref: string }
const { lang, esHref, enHref } = Astro.props as Props;
---
<div class="flex items-center gap-2 border-l border-[var(--line)] pl-5 text-xs leading-none">
  <a href={esHref}
     class={`text-link ${lang === 'es' ? 'text-[var(--text)] line-through' : ''}`}
     onclick={`try{localStorage.setItem('lang','es')}catch{}`}>es</a>
  <span class="muted">/</span>
  <a href={enHref}
     class={`text-link ${lang === 'en' ? 'text-[var(--text)] line-through' : ''}`}
     onclick={`try{localStorage.setItem('lang','en')}catch{}`}>en</a>
</div>
