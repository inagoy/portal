---
interface Props {
  title: string;
  url: string;
  description: string;
  logo: string;
}

const { title, url, description, logo } = Astro.props as Props;
const domain = url.replace(/^https?:\/\//, "").replace(/\/$/, "");
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="project-row group/card"
>
  <div class="flex min-h-[5.5rem] items-center justify-center overflow-hidden rounded-[2px] bg-[var(--soft)] p-4 sm:aspect-square sm:min-h-0 sm:p-5">
    <img
      src={logo}
      alt={`${title} logo`}
      loading="lazy"
      class="max-h-12 max-w-full object-contain opacity-90 sm:max-h-14"
    />
  </div>

  <div class="min-w-0">
    <div class="flex items-start justify-between gap-3 sm:gap-4">
      <h2 class="text-[0.98rem] font-medium leading-tight transition-all group-hover/card:line-through sm:text-base">{title}</h2>
    </div>
    <p class="muted mt-1.5 break-all text-xs sm:mt-2 sm:text-sm">{domain}</p>
    <p class="muted mt-2.5 text-sm sm:mt-3 sm:text-base">{description}</p>
  </div>
</a>
