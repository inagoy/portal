---
interface Props {
  title: string;
  url: string;
  description: string;
  logo: string;
}

const { title, url, description, logo } = Astro.props as Props;
const domain = url.replace(/^https?:\/\//, "").replace(/\/$/, "");
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group/card sm:py-5 py-10 flex flex-col sm:flex-row sm:items-center gap-6"
>
  <div class="w-[266px] mx-auto sm:mx-0 shrink-0 flex flex-col items-center sm:items-start gap-3 py-2">
    <div class="w-full rounded-md border border-white/25 bg-white/10 px-4 py-5 backdrop-blur-[1px]">
      <img
        src={logo}
        alt={`${title} logo`}
        loading="lazy"
        class="h-14 max-w-full w-auto object-contain mx-auto drop-shadow-[0_0_8px_rgba(0,0,0,0.45)]"
      />
    </div>
    <div class="w-full rounded-md border border-white/25 bg-white/10 px-3 py-2 backdrop-blur-[1px] flex items-center justify-center">
      <span class="font-semibold text-base break-all leading-tight text-center">{domain}</span>
    </div>
  </div>

  <div class="text-center sm:text-left mx-auto sm:mx-0 flex flex-col justify-center">
    <h2 class="font-medium mb-2 transition-all group-hover/card:line-through">{title}</h2>
    <p class="opacity-60">{description}</p>
  </div>
</a>
