---
interface Props {
  title: string;
  url: string;
  description: string;
  logo: string;
}

const { title, url, description, logo } = Astro.props as Props;
const domain = url.replace(/^https?:\/\//, "").replace(/\/$/, "");
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="project-row group/card"
>
  <div class="flex aspect-square items-center justify-center border border-[var(--line)] bg-[var(--soft)] p-5">
    <img
      src={logo}
      alt={`${title} logo`}
      loading="lazy"
      class="max-h-14 max-w-full object-contain opacity-90"
    />
  </div>

  <div class="min-w-0">
    <div class="flex items-start justify-between gap-4">
      <h2 class="font-medium leading-tight transition-all group-hover/card:line-through">{title}</h2>
    </div>
    <p class="muted mt-2 break-all text-sm">{domain}</p>
    <p class="muted mt-3">{description}</p>
  </div>
</a>
