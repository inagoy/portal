---
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

import Layout from "../../layouts/Layout.astro";
import { getProgrammingProjectsPageContent, getContactPageContent } from "../../config";
import { normalizeLang, getStrings } from "../../i18n";
import ProjectCard from "../../components/ProgrammingProjectCard.astro";
import SocialLink from "../../components/SocialLink.astro";

const lang = normalizeLang(Astro.params.lang as string);
const t = getStrings(lang);
const programmingProjectsPageContent = getProgrammingProjectsPageContent(lang);
const contactContent = getContactPageContent(lang);
const githubLink = contactContent.links.find((link) => link.title === "github");
---

<Layout seo={programmingProjectsPageContent.seo} lang={lang}>
  <section class="page pt-10">
    <div class="page-header">
      <h1 class="page-title">{t.headings.programming_portfolio}</h1>
      <p class="muted mt-4">{programmingProjectsPageContent.subtitle}</p>
    </div>
    <div class="grid grid-cols-1">
      {
        programmingProjectsPageContent.projects.map((project: any) => (
          <ProjectCard {...project} />
        ))
      }
    </div>
  </section>
  <section class="page mt-12">
    <div class="flex items-center gap-4">
      <h2 class="muted">{t.headings.more_projects_on}</h2>
      {
        githubLink && (
          <SocialLink
            title={githubLink.title}
            url={githubLink.url}
            icon={githubLink.icon}
            external={githubLink.external}
          />
        )
      }
    </div>
  </section>
</Layout>
