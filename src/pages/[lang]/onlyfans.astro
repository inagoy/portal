---
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

import Layout from "../../layouts/Layout.astro";
import { normalizeLang, getStrings } from "../../i18n";
import { identity } from "../../config";

const lang = normalizeLang(Astro.params.lang as string);
const t = getStrings(lang);
const seo = {
  title: `onlyfans | iñaki goyeneche`,
  description: t.onlyfans?.text ?? (lang === 'es' ? 'no tengo xd' : "don't have xd"),
  image: identity.logo,
};
---
<Layout seo={seo} lang={lang}>
  <section class="page grid min-h-[40vh] place-items-center pt-10 text-center">
    <p class="muted text-lg">{t.onlyfans?.text ?? (lang === 'es' ? 'no tengo xd' : "don't have xd")}</p>
  </section>
  <script>
    setTimeout(() => {
      const path = window.location.pathname.replace(/\/onlyfans\/?$/, '/');
      window.location.href = path;
    }, 1200);
  </script>
</Layout>
