---
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

import Layout from "../../layouts/Layout.astro";
import { getMusicProjectsPageContent } from "../../config";
import { normalizeLang, getStrings } from "../../i18n";
import ProjectCard from "../../components/MusicProjectCard.astro";

const lang = normalizeLang(Astro.params.lang as string);
const t = getStrings(lang);
const musicProjectsPageContent = getMusicProjectsPageContent(lang);
---

<Layout seo={musicProjectsPageContent.seo} lang={lang}>
  <section class="page pt-10">
    <div class="page-header">
      <h1 class="page-title">{t.headings.music_portfolio}</h1>
      <p class="muted mt-4">{musicProjectsPageContent.subtitle}</p>
    </div>
    <div class="grid grid-cols-1">
      {
        musicProjectsPageContent.projects.map((project: any) => (
          <ProjectCard {...project} lang={lang} />
        ))
      }
    </div>
  </section>
</Layout>
