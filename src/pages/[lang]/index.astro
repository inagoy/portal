---
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

import Layout from "../../layouts/Layout.astro";
import { getHomePageContent, identity } from "../../config";
import { normalizeLang } from "../../i18n";
import SocialLink from "../../components/SocialLink.astro";
import Link from "../../components/Link.astro";

const lang = normalizeLang(Astro.params.lang as string);
const homePageContent = getHomePageContent(lang);
---
<Layout seo={homePageContent.seo} lang={lang}>
  <section class="page pt-12 sm:pt-24">
    <div class="page-header">
      <h1 class="page-title">{identity.name}</h1>
      <p class="muted mt-3 text-sm sm:mt-4 sm:text-base">{homePageContent.role}</p>
    </div>

    <ul class="flex flex-wrap gap-x-4 gap-y-2.5 sm:gap-x-5 sm:gap-y-3">
      {
        homePageContent.socialLinks.map((link: any) => (
          <li>
            <SocialLink
              title={link.title}
              url={link.url}
              icon={link.icon}
              external={link.external}
              disappearsOnHover={link.disappearsOnHover}
            />
          </li>
        ))
      }
    </ul>

    <div class="mt-10 flex flex-col gap-2.5 sm:mt-12 sm:gap-5">
      {
        homePageContent.links.map((link: any) => (
          <Link text={link.title} href={`/${lang}${link.url}`} external={link.external}/>
        ))
      }
    </div>
  </section>
</Layout>
