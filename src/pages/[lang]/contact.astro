---
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

import Layout from "../../layouts/Layout.astro";
import { getContactPageContent } from "../../config";
import { normalizeLang, getStrings } from "../../i18n";
import SocialLink from "../../components/SocialLink.astro";
import MailForm from "../../components/MailForm.astro";

const lang = normalizeLang(Astro.params.lang as string);
const t = getStrings(lang);
const contactPageContent = getContactPageContent(lang);
---

<Layout seo={contactPageContent.seo} lang={lang}>
  <section class="page pt-10">
    <div class="page-header">
      <h1 class="page-title">{t.headings.contact}</h1>
      <p class="muted mt-4">{contactPageContent.subtitle}</p>
    </div>
  </section>
  <section class="page">
    <MailForm lang={lang}/>
  </section>
  <section class="page mt-12">
    <p class="muted mb-5">{t.headings.my_networks}</p>
    <ul class="flex flex-wrap gap-x-5 gap-y-3">
      {
        contactPageContent.links.map((link: any) => (
          <li>
            <SocialLink title={link.title} url={link.url} icon={link.icon} external={link.external} />
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
