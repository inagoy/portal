---
import { getNavBarLinks, identity } from "../config";
import { normalizeLang, type Lang } from "../i18n";
import LanguageSelector from "../components/LanguageSelector.astro";
import type { SEOInfo } from "../types/config";

interface Props {
  seo: SEOInfo;
  lang?: Lang;
}

const { seo } = Astro.props;
const url = Astro.url;
const currentUrl = url.pathname.endsWith('/') ? url.pathname.slice(0, -1) : url.pathname;
const paramLang = url.searchParams.get('lang');
const pageLang: Lang = normalizeLang(paramLang ?? (Astro.props.lang as string | undefined));
const navBarLinks = getNavBarLinks(pageLang);
function withLangPath(u: URL, lang: string): string {
  const rest = u.pathname.replace(/^\/(en|es)/, '');
  const path = `/${lang}${rest}`;
  return path;
}
const esHref = withLangPath(url, 'es');
const enHref = withLangPath(url, 'en');

---

<style is:global>
  @font-face {
    font-family: "Inter";
    src: url("/fonts/InterVariable.woff2") format("woff2");
    font-weight: 100 900;
    font-display: swap;
  }

  :root {
    --bg: #1a0c0d;
    --text: #f5f1e8;
    --muted: rgba(245, 241, 232, 0.58);
    --line: rgba(245, 241, 232, 0.14);
    --soft: rgba(245, 241, 232, 0.06);
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: "Inter", system-ui, sans-serif;
    overflow-y: scroll;
  }

  * {
    box-sizing: border-box;
    color: inherit;
    margin: 0;
    padding: 0;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    padding-right: calc(100vw - 100%);
    text-transform: lowercase;
  }

  a {
    text-decoration: none;
  }

  .page {
    max-width: 42rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    margin-bottom: 3.5rem;
  }

  .page-title {
    font-size: clamp(2rem, 7vw, 4.25rem);
    font-weight: 520;
    line-height: 0.95;
  }

  .muted {
    color: var(--muted);
  }

  .text-link {
    color: var(--muted);
    transition: color 180ms ease, text-decoration-color 180ms ease;
  }

  .text-link:hover,
  .text-link:focus-visible {
    color: var(--text);
    text-decoration: line-through;
    outline: none;
  }

  .project-row {
    display: grid;
    gap: 1rem;
    border-top: 1px solid var(--line);
    padding: 1.5rem 0;
  }

  @media (min-width: 640px) {
    .project-row {
      grid-template-columns: 8rem 1fr;
    }
  }

  .field {
    width: 100%;
    border: 1px solid var(--line);
    background: transparent;
    padding: 0.85rem 1rem;
    color: var(--text);
    outline: none;
  }

  .field::placeholder {
    color: var(--muted);
  }

  .field:focus {
    border-color: var(--text);
  }

  .button {
    border: 1px solid var(--line);
    background: transparent;
    padding: 0.85rem 1.1rem;
    color: var(--muted);
    transition: color 180ms ease, border-color 180ms ease;
  }

  .button:hover,
  .button:focus-visible {
    border-color: var(--text);
    color: var(--text);
    text-decoration: line-through;
    outline: none;
  }
</style>

<html lang={pageLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={seo.image} />
    
  </head>
  <body>
    <header>
      <div
        class="page flex items-center justify-between py-8"
      >
        <a href={`/${pageLang}/`} class="text-link text-sm">
          <img
            src={identity.logo}
            alt={"Logo"}
            width="46"
            height="46"
            class="block opacity-90"
          />
        </a>
        <nav class="ml-auto flex items-center gap-5 text-sm">
          <ul class="hidden sm:flex sm:items-center sm:gap-5">
            {
              navBarLinks.map((link) => (
                <li>
                  <a
                    class={`text-link whitespace-nowrap ${currentUrl === link.url ? 'text-[var(--text)] line-through' : ''}`}
                    href={link.url}
                    target={link.external ? "_blank" : "_self"}
                  >
                    {link.title}
                  </a>
                </li>
              ))
            }
          </ul>
          <div class="relative sm:hidden">
            <button
              id="link-menu-button"
              class="text-link inline-flex items-center gap-1 whitespace-nowrap"
              >menu <span id="open-indicator">+</span></button
            >
            <div
              id="link-menu"
              class="pointer-events-none absolute right-0 top-8 z-40 w-44 border border-[var(--line)] bg-[var(--bg)] p-3 opacity-0 transition-opacity duration-200"
            >
              <ul>
                {
                  navBarLinks.map((link) => (
                    <li>
                      <a
                        class={`text-link block py-2 whitespace-nowrap ${currentUrl === link.url ? 'text-[var(--text)] line-through' : ''}`}
                        href={link.url}
                        target={link.external ? "_blank" : "_self"}
                      >
                        {link.title}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
          <LanguageSelector lang={pageLang} esHref={esHref} enHref={enHref} />
        </nav>
      </div>
    </header>
    <main class="pb-28">
      <slot />
    </main>
    <footer></footer>
  </body>
</html>

<script>
  const linkMenuButton = document.getElementById(
    "link-menu-button"
  ) as HTMLButtonElement;
  const linkMenu = document.getElementById("link-menu") as HTMLDivElement;
  const openIndicator = document.getElementById(
    "open-indicator"
  ) as HTMLSpanElement;

  linkMenuButton.addEventListener("click", () => {
    if (linkMenu.classList.contains("opacity-0")) {
      linkMenu.classList.remove("pointer-events-none");
      linkMenu.classList.remove("opacity-0");
      openIndicator.innerText = "-";
    } else {
      linkMenu.classList.add("pointer-events-none");
      linkMenu.classList.add("opacity-0");
      openIndicator.innerText = "+";
    }
  });

  document.addEventListener("click", (event) => {
    const isLinkMenuButtonClicked =
      event.target === linkMenuButton ||
      linkMenuButton.contains(event.target as Node);
    const isLinkMenuClicked =
      event.target === linkMenu || linkMenu.contains(event.target as Node);

    if (!isLinkMenuButtonClicked && !isLinkMenuClicked) {
      linkMenu.classList.add("pointer-events-none");
      linkMenu.classList.add("opacity-0");
      openIndicator.innerText = "+";
    }
  });
</script>
